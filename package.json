{
  "name": "podcast-summarizer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "verify:cf-preview": "node scripts/verify-cloudflare-preview.mjs",
    "verify:cf-preview:visual": "node scripts/verify-cloudflare-visual.mjs",
    "verify:cf-production": "node scripts/verify-cloudflare-production.mjs",
    "baseline:capture": "node scripts/capture-cloudflare-baseline.mjs",
    "audit:data-migration": "node scripts/audit-cloudflare-data-migration.mjs",
    "cutover:prepare": "node scripts/prepare-cloudflare-cutover.mjs",
    "cutover:preflight": "node scripts/preflight-cloudflare-cutover.mjs",
    "cutover:dry-run": "node scripts/dry-run-cloudflare-cutover.mjs",
    "d1:export-sql": "node scripts/export-postgres-to-d1-sql.mjs",
    "d1:import-postgres": "node scripts/import-postgres-to-d1.mjs",
    "d1:apply-r2-manifest": "node scripts/apply-r2-migration-manifest-d1.mjs",
    "r2:apply-manifest": "node scripts/apply-r2-migration-manifest.mjs",
    "r2:rollback-manifest": "node scripts/rollback-r2-migration-manifest.mjs",
    "lint": "eslint .",
    "test": "npm run type-check && jest",
    "test:watch": "jest --watch",
    "test:db": "jest __tests__/lib/",
    "test:api": "jest __tests__/api/",
    "test:components": "jest __tests__/dashboard/",
    "test:working": "jest __tests__/lib/ && jest __tests__/api/db-init.test.ts",
    "test:coverage": "jest --coverage",
    "test:debug": "jest --runInBand --no-coverage --no-cache",
    "test:clear": "jest --clearCache",
    "test:requests": "ts-node scripts/test-requests.ts",
    "youtube:fetch": "node scripts/utils/youtube-fetch.mjs",
    "summary:bilingual:rebuild": "node scripts/rebuild-bilingual-summary.mjs",
    "summary:en:rebuild": "node scripts/rebuild-summary-en.mjs",
    "fulltext:en:rebuild": "node scripts/rebuild-full-text-en.mjs",
    "tags:rebuild": "node scripts/rebuild-podcast-tags.mjs",
    "brief:rebuild": "node scripts/rebuild-brief-summary.mjs",
    "mindmap:rebuild": "node scripts/rebuild-mind-map.mjs",
    "vocab:build": "node scripts/build-advanced-vocab.mjs",
    "pronunciation:build": "node scripts/build-pronunciation-library.mjs",
    "type-check": "tsc --noEmit",
    "test:full": "npm run type-check && npm run test:coverage",
    "db:init": "node -r dotenv/config scripts/init-db.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@ant-design/graphs": "^2.1.1",
    "@auth/prisma-adapter": "^2.10.0",
    "@distube/ytdl-core": "^4.16.12",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/bcryptjs": "^2.4.6",
    "@vercel/blob": "^1.0.1",
    "@vercel/postgres": "^0.10.0",
    "ai": "^4.3.15",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "nanoid": "^5.1.5",
    "next": "^15.5.18",
    "next-auth": "^4.24.11",
    "openai-edge": "^1.2.2",
    "pg": "^8.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "undici": "^7.21.0",
    "uuid": "^11.1.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@edge-runtime/jest-environment": "^4.0.0",
    "@eslint/eslintrc": "^3",
    "@stagewise-plugins/react": "^0.4.7",
    "@stagewise/toolbar-next": "^0.4.7",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.10",
    "@types/node": "^20",
    "@types/node-fetch": "^2.6.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "node-fetch": "^2.7.0",
    "playwright": "^1.53.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wrangler": "^4.98.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
