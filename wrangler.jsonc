{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "podcast-summarizer",
  "main": "worker.ts",
  "compatibility_date": "2026-06-08",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "podsum.cc",
      "custom_domain": true
    },
    {
      "pattern": "www.podsum.cc",
      "custom_domain": true
    }
  ],
  "r2_buckets": [
    {
      "binding": "PODSUM_BUCKET",
      "bucket_name": "podsum-uploads"
    }
  ],
  "d1_databases": [
    {
      "binding": "PODSUM_DB",
      "database_name": "podsum-d1-production",
      "database_id": "5d0b65e0-d556-4aa4-953f-4d680d11c34a",
      "migrations_dir": "migrations/d1"
    }
  ],
  "vars": {
    "STORAGE_PROVIDER": "r2",
    "DATABASE_PROVIDER": "d1",
    "DEPLOYMENT_STAGE": "production",
    "ENABLE_CRON": "true",
    "PROCESS_WORKER_CONCURRENCY": "1",
    "PROCESSING_JOB_LEASE_SECONDS": "300",
    "CHROME_EXTENSION_IDS": "bgohgakmnepefbcccanofomnhodflnab",
    "OPENROUTER_MODEL": "openai/gpt-4o-mini",
    "OPENROUTER_MINDMAP_MODEL": "openai/gpt-4o-mini",
    "ADMIN_EMAILS": "chenzixin1@gmail.com",
    "NEXTAUTH_URL": "https://podsum.cc",
    "NEXT_PUBLIC_APP_URL": "https://podsum.cc"
  },
  "triggers": {
    "crons": ["* * * * *", "0 4 * * *"]
  },
  "observability": {
    "enabled": true
  },
  "workers_dev": false
}
